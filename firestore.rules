rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Snapshots: Allow read/write for the backend to manage the cache.
    // In a prototype environment using the Client SDK on the backend, 
    // we need to explicitly allow this access.
    match /snapshots/{date} {
      allow read, write: if true;
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Snapshots: Allow read/write for the backend to manage the cache.
    // We use document tracking {date=**} to allow access to subcollections as well.
    match /snapshots/{allPaths=**} {
      allow read, write: if true;
    }
  }
}
